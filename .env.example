# korb-guru Environment Configuration
# Copy to .env and fill in your values.

# --- PostgreSQL (Coolify: korb-guru-db) ---
DATABASE_URL=postgresql+psycopg://korb:CHANGE_ME@korb-guru-db:5432/korb_guru

# --- Qdrant Cloud ---
QDRANT_MODE=cloud
QDRANT_URL=https://xxx.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-cloud-key

# --- Embeddings ---
EMBEDDING_PROVIDER=local

# --- LLM (at least one required for AI features) ---
# Primary: Apify OpenRouter proxy
APIFY_TOKEN=your-apify-token
# Fallback: Direct OpenRouter
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_DEFAULT_MODEL=google/gemini-2.5-flash

# --- Ingest Auth ---
# INGEST_API_KEY=your-random-ingest-key

# --- Auth ---
AUTH_DEV_MODE=false
# CLERK_FRONTEND_API_URL=https://your-app.clerk.accounts.dev

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8001

# --- App ---
API_PORT=8001
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
LOG_LEVEL=INFO
